{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ts:bats",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/wings_particles"
      }
    },
    "components": {
      "minecraft:emitter_local_space": { "position": true, "rotation": true },
      "minecraft:emitter_rate_instant": { "num_particles": 18 },
      "minecraft:emitter_lifetime_once": { "active_time": 0.2 },
      "minecraft:emitter_shape_sphere": {
        "radius": 0.25,
        "direction": "outwards"
      },
      "minecraft:particle_initial_speed": "Math.random(2.5, 4.5)",
      "minecraft:particle_lifetime_expression": { "max_lifetime": 1.6 },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, 1.5, 0],
        "linear_drag_coefficient": 1.1,
        "rotation_acceleration": "Math.random(-260, 260)",
        "rotation_drag_coefficient": 0.8
      },
      "minecraft:particle_initial_spin": { "rotation": "Math.random(0, 360)" },
      "minecraft:particle_appearance_billboard": {
        "size": [0.28, 0.18],
        "facing_camera_mode": "rotate_xyz",
        "uv": { "texture_width": 64, "texture_height": 64, "uv": [0, 0], "uv_size": [16, 16] }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "0.07 + 0.10 * (0.5 + 0.5 * Math.cos(variable.particle_age * 720))",
          "0.05",
          "0.12 + 0.10 * (0.5 + 0.5 * Math.cos(variable.particle_age * 720))",
          "math.max(0.0, 1.0 - (variable.particle_age / variable.particle_lifetime))"
        ]
      }
    }
  }
}
