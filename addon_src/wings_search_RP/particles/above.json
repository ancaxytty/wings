{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "wings:above",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/wings_particles"
      }
    },
    "components": {
      "minecraft:emitter_local_space": { "position": true, "rotation": true },
      "minecraft:emitter_rate_instant": { "num_particles": 5 },
      "minecraft:emitter_lifetime_once": { "active_time": 0.2 },
      "minecraft:emitter_shape_sphere": { "radius": 0.28, "direction": "outwards" },
      "minecraft:particle_initial_speed": 0.35,
      "minecraft:particle_lifetime_expression": { "max_lifetime": 1.4 },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [ 0, 0.9, 0 ],
        "linear_drag_coefficient": 1.4,
        "rotation_acceleration": 90.0,
        "rotation_drag_coefficient": 1.0
      },
      "minecraft:particle_appearance_billboard": {
        "size": [ 0.14, 0.14 ],
        "facing_camera_mode": "rotate_xyz",
        "uv": { "texture_width": 64, "texture_height": 64, "uv": [ 0, 0 ], "uv_size": [ 16, 16 ] }
      },
      "minecraft:particle_initial_spin": { "rotation": "Math.random(0, 360)" },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "variable.color.r",
          "variable.color.g",
          "variable.color.b",
          "math.max(0.0, 1.0 - (variable.particle_age / variable.particle_lifetime))"
        ]
      }
    }
  }
}
