{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "wings:rune",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/wings_celebration2"
      }
    },
    "components": {
      "minecraft:emitter_local_space": { "position": true, "rotation": true },
      "minecraft:emitter_rate_instant": { "num_particles": 1 },
      "minecraft:emitter_lifetime_once": { "active_time": 0.05 },
      "minecraft:emitter_shape_point": { "offset": [ 0, 0, 0 ] },
      "minecraft:particle_initial_speed": 0,
      "minecraft:particle_lifetime_expression": { "max_lifetime": 0.75 },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [ 0, 0.4, 0 ],
        "linear_drag_coefficient": 0.3,
        "rotation_acceleration": 90.0,
        "rotation_drag_coefficient": 0.6
      },
      "minecraft:particle_appearance_billboard": {
        "size": [ 0.28, 0.28 ],
        "facing_camera_mode": "rotate_xyz",
        "uv": { "texture_width": 64, "texture_height": 64, "uv": [ 16, 16 ], "uv_size": [ 16, 16 ] }
      },
      "minecraft:particle_initial_spin": { "rotation": "Math.random(0, 360)" },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "variable.color.r", "variable.color.g", "variable.color.b",
          "math.max(0.0, 1.0 - math.pow(variable.particle_age / variable.particle_lifetime, 2))"
        ]
      }
    }
  }
}
